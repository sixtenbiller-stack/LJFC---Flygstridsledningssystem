{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peace-keeper.app/schemas/llm/situation_brief.schema.json",
  "title": "NEON COMMAND LLM Situation Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary",
    "why_it_matters",
    "recommended_next_action",
    "confidence",
    "cited_ids"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "neon.llm.situation_brief.v1" },
    "summary": { "type": "string" },
    "why_it_matters": { "type": "string" },
    "recommended_next_action": { "type": "string" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "cited_ids": { "type": "array", "items": { "type": "string" } }
  }
}
