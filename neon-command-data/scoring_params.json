{
  "schema_version": "neon.scoring.v1",
  "meta": {
    "version": "minimal-v1",
    "description": "Minimal threat scoring parameters for NEON COMMAND initial phase."
  },
  "scoring_weights": {
    "heading_toward_defended_zone": 0.35,
    "time_to_zone_inverse": 0.3,
    "speed_class_factor": 0.2,
    "confidence_level": 0.15
  },
  "speed_class_map": {
    "slow": 0.3,
    "medium": 0.6,
    "fast": 1.0
  },
  "altitude_band_map": {
    "very_low": {
      "label": "< 500m",
      "detection_penalty": 0.2,
      "sam_engagement_bonus": -0.1
    },
    "low": {
      "label": "500-3000m",
      "detection_penalty": 0.0,
      "sam_engagement_bonus": 0.0
    },
    "medium": {
      "label": "3000-10000m",
      "detection_penalty": 0.0,
      "sam_engagement_bonus": 0.1
    },
    "high": {
      "label": "> 10000m",
      "detection_penalty": 0.0,
      "sam_engagement_bonus": 0.15
    }
  },
  "confidence_threshold_for_alert": 0.55,
  "confidence_threshold_for_high_priority": 0.75,
  "threat_score_thresholds": {
    "low": 0.3,
    "medium": 0.5,
    "high": 0.7,
    "critical": 0.85
  },
  "heading_tolerance_deg": 35,
  "raid_association_distance_km": 50,
  "raid_association_time_window_s": 30
}
