# LJFC COMMAND environment configuration

# Local AI (LM Studio) configuration
# If LMSTUDIO_BASE_URL is set, it will be used instead of Gemini
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL=local-model

# Gemini API key (Internet AI provider)
# Accepted variable names: GEMINI_API_KEY, GOOGLE_AI_STUDIO_KEY, GOOGLE_API_KEY
GEMINI_API_KEY=

# Optional: override Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Legacy LLM mode override (mock = no AI calls)
# LLM_MODE=mock

# Data path (default: ../neon-command-data)
# DATA_PATH=../neon-command-data
