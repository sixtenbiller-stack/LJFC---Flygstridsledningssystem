# NEON COMMAND environment configuration

# Gemini API key (default AI provider)
# Accepted variable names: GEMINI_API_KEY, GOOGLE_AI_STUDIO_KEY, GOOGLE_API_KEY
GEMINI_API_KEY=

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Legacy LLM mode override (mock = no AI calls)
# LLM_MODE=mock

# Data path (default: ../neon-command-data)
# DATA_PATH=../neon-command-data
