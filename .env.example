# LJFC COMMAND environment configuration

# Local AI — OpenAI-compatible API (LM Studio, Ollama, etc.)
# If LMSTUDIO_BASE_URL is set, it will be used instead of Gemini.
# Ollama (typical):
#   LMSTUDIO_BASE_URL=http://127.0.0.1:11434
#   LMSTUDIO_MODEL=gemma4:e2b
# LM Studio: use your server URL, often http://127.0.0.1:1234
# Optional (Ollama on a non-default port): set to none|low|medium|high to control Gemma 3/4 "thinking"
# LMSTUDIO_REASONING_EFFORT=none
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL=local-model

# Gemini API key (Internet AI provider)
# Accepted variable names: GEMINI_API_KEY, GOOGLE_AI_STUDIO_KEY, GOOGLE_API_KEY
GEMINI_API_KEY=

# Optional: override Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Legacy LLM mode override (mock = no AI calls)
# LLM_MODE=mock

# Data path (default: ../neon-command-data)
# DATA_PATH=../neon-command-data
